{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "test:save": "sh -c 'mkdir -p test-results && jest --runInBand --verbose 2>&1 | tee test-results/result_$(date +%Y%m%d_%H%M%S).txt'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mysql2": "^3.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/supertest": "^6",
    "jest": "^29",
    "supertest": "^7",
    "ts-jest": "^29",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  }
}
