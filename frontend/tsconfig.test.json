{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "incremental": false,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./src/*"],
      "@testing-library/react": ["/tmp/frontend-test-deps/node_modules/@testing-library/react"],
      "@testing-library/jest-dom": ["/tmp/frontend-test-deps/node_modules/@testing-library/jest-dom"]
    },
    "baseUrl": ".",
    "types": ["jest", "node"],
    "typeRoots": [
      "/tmp/frontend-test-deps/node_modules/@types",
      "/tmp/frontend-test-deps/node_modules/@testing-library",
      "./node_modules/@types"
    ]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
