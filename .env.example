# ============================================================
# 環境変数サンプル
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=password

# --- Backend ---
NODE_ENV=development
PORT=4000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
# サーバーサイド（Server Component）からバックエンドへ接続するための内部URL
# Docker ネットワーク内ではサービス名 "backend" で疎通できる
INTERNAL_API_URL=http://backend:4000
